{
  "expo": {
    "name": "Surveillance Doc",
    "slug": "injury-reporting-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/surveillance-doc-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundImage": "./assets/icon-background.png",
        "backgroundColor": "#001a79"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "package": "com.anonymous.injuryreportingapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-file-system",
        {
          "enableFileSharing": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#001a79",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-notifications",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Rubik-VariableFont_wght.ttf"
          ]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "fbf4fbc3-856f-4741-b236-01cbde28c162"
      }
    }
  }
}
